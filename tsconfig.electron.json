{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "module": "CommonJS",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node", "electron"],
    "moduleResolution": "node",
    "strict": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["electron/**/*.ts", "electron/*.ts", "electron/*.api.ts"],
  "exclude": ["node_modules"]
}
